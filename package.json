{
  "name": "codex-of-solana",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test:unit && turbo test:integration",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.3.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
