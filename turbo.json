{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "test:unit": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [],
      "cache": false
    },
    "test:integration": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["test:unit", "test:integration"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
